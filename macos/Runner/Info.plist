<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIconFile</key>
	<string></string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<!-- Register the hinata:// custom scheme so Launch Services routes the SSO /
	     invite / reset-password deep links to this app (handled by app_links). -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.ahmadre.hinata</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>hinata</string>
			</array>
		</dict>
	</array>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<!-- Let app_links be the single deep-link handler. Otherwise Flutter's
	     built-in deep linking also routes the raw hinata://auth-callback URI
	     into go_router, which can't match it ("Page Not Found"). -->
	<key>FlutterDeepLinkingEnabled</key>
	<false/>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.productivity</string>
	<key>LSMinimumSystemVersion</key>
	<string>$(MACOSX_DEPLOYMENT_TARGET)</string>
	<key>NSHumanReadableCopyright</key>
	<string>$(PRODUCT_COPYRIGHT)</string>
	<!-- Voice comments: recording an audio message needs microphone access.
	     macOS TCC hard-crashes (SIGABRT, "Namespace TCC") the moment the mic is
	     touched without this usage-description key present. -->
	<key>NSMicrophoneUsageDescription</key>
	<string>Hinata needs microphone access so you can record voice messages on issue comments and activity.</string>
	<!-- Composer "+" menu: photo/camera pickers. App Store review rejects a
	     build whose binary links these APIs without the matching usage
	     descriptions, even if the sandboxed picker only opens a file dialog. -->
	<key>NSCameraUsageDescription</key>
	<string>Hinata needs camera access so you can capture photos and videos for issue comments and attachments.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Hinata needs photo library access so you can attach photos and videos to issue comments and attachments.</string>
	<key>NSMainNibFile</key>
	<string>MainMenu</string>
	<key>NSPrincipalClass</key>
	<string>NSApplication</string>
</dict>
</plist>
