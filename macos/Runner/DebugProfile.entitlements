<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<!-- Voice comments: record from the microphone. -->
	<key>com.apple.security.device.audio-input</key>
	<true/>
	<key>com.apple.security.network.server</key>
	<true/>
	<key>com.apple.security.network.client</key>
	<true/>
	<!-- Attachments & inline photos: file_picker/image_picker open an
	     NSOpenPanel; without this the sandboxed panel returns nothing and the
	     composer's upload buttons silently do nothing. -->
	<key>com.apple.security.files.user-selected.read-only</key>
	<true/>
	<!-- NOTE: `aps-environment` (push) and `com.apple.developer.associated-domains`
	     are DELIBERATELY absent here. They require a provisioning profile from a
	     real development team; the local `flutter run -d macos` config signs
	     ad-hoc ("Sign to Run Locally": CODE_SIGN_IDENTITY = "-", no DEVELOPMENT_TEAM),
	     which cannot satisfy them — Xcode then fails the build with "Runner has
	     entitlements that require signing with a development certificate."
	     They live only in Release.entitlements, which the fastlane distribution
	     build signs manually with the matching profile. Consequence: FCM push and
	     universal links don't work in a local macOS debug run (fine for dev);
	     re-adding either here breaks `flutter run -d macos` again. -->
</dict>
</plist>
