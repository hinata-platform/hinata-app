# Hinata — macOS (Mac App Store) release automation.
#
# Mirrors the iOS lanes but targets the Mac platform: match also fetches the
# "Mac Installer Distribution" certificate so gym can sign the .pkg, and uploads
# use the macOS (osx) App Store Connect platform.
#
#   bundle exec fastlane mac bootstrap   # one-time: App ID + macOS certs/profiles
#   bundle exec fastlane mac signing     # fetch certs/profiles (read-only on CI)
#   bundle exec fastlane mac beta        # build + upload to TestFlight (macOS)
#   bundle exec fastlane mac release     # build + submit to the Mac App Store

default_platform(:mac)

# gym probes `xcodebuild -showBuildSettings` before archiving. On a cold CI
# runner the very first xcodebuild invocation resolves the workspace/SPM state
# and can take minutes; fastlane's 3s default timeout then fails the lane.
# `||=` keeps an explicit override from the environment authoritative.
ENV["FASTLANE_XCODEBUILD_SETTINGS_TIMEOUT"] ||= "120"
ENV["FASTLANE_XCODEBUILD_SETTINGS_RETRIES"] ||= "6"

APP_IDENTIFIER = "com.ahmadre.hinata".freeze
WORKSPACE = "Runner.xcworkspace".freeze
SCHEME = "Runner".freeze
# gym appends the ".pkg" extension to output_name, so the base name must NOT
# include it (else the artefact lands at hinata.pkg.pkg and the upload can't
# find it). PKG_NAME is the resulting file; PKG_BASENAME is what gym is given.
PKG_DIR = "../build/macos/pkg".freeze
PKG_BASENAME = "hinata".freeze
PKG_NAME = "#{PKG_BASENAME}.pkg".freeze

def ci?
  ENV["CI"] == "true"
end

# Sets the global App Store Connect API key; nested actions read it from the
# lane context (passing it on triggers an api_key/api_key_path conflict in cert).
def auth!
  path = ENV["HINATA_ASC_KEY_PATH"]
  path = File.expand_path(path, __dir__) if path && !path.start_with?("/")
  common = {
    key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
    issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"]
  }
  if path && File.exist?(path)
    app_store_connect_api_key(**common, key_filepath: path)
  else
    app_store_connect_api_key(**common,
                              key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
                              is_key_content_base64: true)
  end
end

def next_build_number
  latest = begin
    latest_testflight_build_number(app_identifier: APP_IDENTIFIER, platform: "osx")
  rescue StandardError
    0
  end
  latest.to_i + 1
end

def flutter(*args)
  Dir.chdir("../..") { sh("flutter", *args) }
end

platform :mac do
  before_all do
    setup_ci if ci?
  end

  desc "One-time: create the macOS dev + App Store signing assets in the match repo"
  lane :bootstrap do
    auth!
    # App ID + App Store Connect record already exist (shared with iOS).
    match(type: "development", app_identifier: APP_IDENTIFIER,
          platform: "macos", readonly: false)
    match(type: "appstore", app_identifier: APP_IDENTIFIER,
          platform: "macos", additional_cert_types: ["mac_installer_distribution"],
          readonly: false)
    UI.success("macOS signing assets are in the match repo. CI can now run read-only.")
  end

  desc "Fetch signing certificates & profiles (read-only on CI)"
  lane :signing do
    auth!
    match(type: "development", app_identifier: APP_IDENTIFIER,
          platform: "macos", readonly: ci?)
    match(type: "appstore", app_identifier: APP_IDENTIFIER,
          platform: "macos", additional_cert_types: ["mac_installer_distribution"],
          readonly: ci?)
  end

  desc "Build a signed Mac App Store .pkg"
  lane :build do
    auth!
    match(type: "appstore", app_identifier: APP_IDENTIFIER,
          platform: "macos", additional_cert_types: ["mac_installer_distribution"],
          readonly: ci?)

    # Pin the Runner target to manual signing with the App Store profile match just
    # installed BEFORE building. Unlike `flutter build ios`, `flutter build macos`
    # has no --no-codesign flag, so the flutter build itself invokes xcodebuild and
    # signs the .app. With the project's default Automatic signing, that build fails
    # on CI ("No profiles for 'com.ahmadre.hinata' were found … Automatic signing is
    # disabled"), because CI has no interactive Apple account to generate a Mac App
    # Development profile and only the appstore profile is installed. Forcing manual
    # signing to the exact installed profile name lets the flutter build sign
    # directly against it — and also gives the archive a team (avoids the later
    # "exportArchive No Team Found in Archive"). The ID in the profile name drifts on
    # regeneration, so resolve it from match's lane context instead of hardcoding.
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Runner.xcodeproj",
      team_id: "T852K29HWS",
      targets: ["Runner"],
      code_sign_identity: "Apple Distribution",
      profile_name: lane_context[SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING][APP_IDENTIFIER]
    )

    # No baked-in backend: the store app must NOT pin a backend. A fresh install asks
    # for the server URL on first launch, so no HINATA_DEFAULT_SERVER define.
    flutter("build", "macos", "--release",
            "--build-number=#{next_build_number}")

    build_app(
      workspace: WORKSPACE,
      scheme: SCHEME,
      export_method: "app-store",
      export_team_id: "T852K29HWS",
      output_directory: PKG_DIR,
      output_name: PKG_BASENAME,
      export_options: {
        provisioningProfiles: lane_context[SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING]
      }
    )
  end

  desc "Build and upload to TestFlight (macOS)"
  lane :beta do
    build
    upload_to_testflight(
      pkg: "#{PKG_DIR}/#{PKG_NAME}",
      app_platform: "osx",
      skip_waiting_for_build_processing: true
    )
  end

  desc "Build + upload .pkg, metadata & screenshots to the Mac App Store. SUBMIT=true also submits for review."
  lane :release do
    build
    submit = ENV["SUBMIT"] == "true"
    upload_to_app_store(
      pkg: "#{PKG_DIR}/#{PKG_NAME}",
      platform: "osx",
      submit_for_review: submit,  # SUBMIT=true → auto-submit; else upload a draft
      automatic_release: false,   # you still control the go-live after approval
      submission_information: submit ? { add_id_info_uses_idfa: false } : nil,
      force: true,
      run_precheck_before_submit: false,
      precheck_include_in_app_purchases: false,
      # Upload the localized macOS listing (fastlane/metadata) + the framed
      # 2880x1800 MacBook screenshots (fastlane/screenshots).
      skip_metadata: false,
      skip_screenshots: false,
      overwrite_screenshots: true
    )
  end
end
