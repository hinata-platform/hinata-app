default_platform(:android)

platform :android do
  desc "Build the app bundle and upload it to the Play Store internal track"
  lane :internal do
    Dir.chdir("../..") do
      # No baked-in backend: the store app must NOT pin a backend. A fresh install asks
      # for the server URL on first launch, so no HINATA_DEFAULT_SERVER define.
      sh("flutter", "build", "appbundle", "--release")
    end
    upload_to_play_store(
      json_key_data: ENV["PLAY_JSON_KEY"], # Play service account JSON (secret)
      track: "internal",
      aab: "../build/app/outputs/bundle/release/app-release.aab",
      release_status: "draft",
      # Upload the full store listing too: title/short/full descriptions +
      # localized changelogs (fastlane/metadata/android) and the framed phone +
      # 10" tablet screenshots (fastlane/metadata/android/<loc>/images). The app
      # icon + 1024x500 feature graphic live under images/ as well when present.
      skip_upload_metadata: false,
      skip_upload_images: false,
      skip_upload_screenshots: false,
      # Don't let a missing optional image (e.g. a 7" tablet set) abort the run.
      sync_image_upload: false
    )
  end

  desc "Promote the latest internal build to production"
  lane :promote do
    upload_to_play_store(
      json_key_data: ENV["PLAY_JSON_KEY"], # Play service account JSON (secret)
      track: "internal",
      track_promote_to: "production",
      skip_upload_aab: true,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end
end
